GEMINI_API_KEY=your_gemini_api_key_here

# Current IT Routine Work sheet (Google Sheets URL: spreadsheets/d/{SHEET_ID}/edit?gid={SHEET_GID})
SHEET_ID=your_current_sheet_id
SHEET_GID=your_current_sheet_tab_gid

# Archived records sheet
SHEET_ID_ARCHIVE=your_archive_sheet_id
SHEET_GID_ARCHIVE=your_archive_sheet_tab_gid

# Google OAuth credentials (Web Application type)
# Setup: console.cloud.google.com → APIs & Services → Credentials → Create OAuth 2.0 Client
# Then run: node scripts/get-google-token.js
GOOGLE_CLIENT_ID=your_oauth_client_id
GOOGLE_CLIENT_SECRET=your_oauth_client_secret
GOOGLE_REFRESH_TOKEN=your_refresh_token
